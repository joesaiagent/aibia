ANTHROPIC_API_KEY=sk-ant-...
TAVILY_API_KEY=tvly-...

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# SMTP Email (simplest setup — works with Gmail app password)
# 1. Enable 2FA at myaccount.google.com/security
# 2. Create app password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=aibia

# Frontend URL (change when deployed)
FRONTEND_URL=http://localhost:5174

# Gmail — set up at https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/email/oauth/callback

# Outlook — set up at https://portal.azure.com
MICROSOFT_CLIENT_ID=
MICROSOFT_TENANT_ID=common
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/email/oauth/callback

# Social platforms (requires developer accounts)
# Instagram/Facebook: https://developers.facebook.com
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# X/Twitter (Elevated access): https://developer.twitter.com
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_BEARER_TOKEN=

# TikTok: https://developers.tiktok.com
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# LinkedIn: https://www.linkedin.com/developers
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
